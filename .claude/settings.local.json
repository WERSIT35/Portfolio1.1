{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx ng *)",
      "Bash(npx tsc *)",
      "Bash(npm test *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git commit -q -m 'Monochrome foundation: pure greyscale tokens + flat background *)",
      "Bash(git commit -q -m 'Homepage: full-bleed inverted Anton hero, flat editorial cards *)",
      "Bash(grep -q \"Local:\" /tmp/ng-serve.log)",
      "Bash(break)",
      "Read(//tmp/**)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(rm -rf *)"
    ]
  },
  "output": {
    "style": "concise",
    "prefer_direct_edits": true,
    "include_changed_files": true,
    "avoid_long_explanations": true
  }
}
