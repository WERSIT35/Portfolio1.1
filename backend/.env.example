# Local MongoDB (default). For Atlas, swap to:
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/portfolio

# Generate a long random string for production. Min 32 chars.
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

PORT=4300
CORS_ORIGIN=http://localhost:4200

# Upload storage
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_PATH=/uploads
MAX_UPLOAD_MB=5

# Seed credentials (only used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@portfolio.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Oto Davitashvili
